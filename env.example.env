# ============================================
# IMAKSA BACKEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file, rename to .env, fill in your values
# NEVER share your .env file with anyone!

# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── MONGODB ──
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/imaksa_db

# ── JWT SECRET ──
# Make this a long random string (50+ characters)
# You can generate one at: https://randomkeygen.com
JWT_SECRET=your_super_secret_jwt_key_make_it_long_and_random_12345
JWT_EXPIRES_IN=30d

# ── EMAIL (Gmail) ──
# Use Gmail App Password (NOT your normal Gmail password)
# Gmail → Settings → Security → 2FA → App Passwords → Generate
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_character_app_password

# ── CLIENT EMAIL (Where enquiries get sent) ──
# This is the IMAKSA owner's email
CLIENT_EMAIL=info@imaksa.ae

# ── FRONTEND URL (for CORS) ──
FRONTEND_URL=https://imaksa.ae

# ── ADMIN ──
# Default admin credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=imaksa2025

