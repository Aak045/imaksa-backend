# ============================================
# IMAKSA BACKEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file, rename to .env, fill in your values
# NEVER share your .env file with anyone!

# ── SERVER ──
PORT=3000
NODE_ENV=development

# ── MONGODB ──
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE
MONGO_URI=mongodb+srv://aakib045:Palavan4545@cluster0.e5lcg0b.mongodb.net/imaksa_db?appName=Cluster0

# ── JWT SECRET ──
# Make this a long random string (50+ characters)
# You can generate one at: https://randomkeygen.com
JWT_SECRET=imaksa_jwt_secret_key_2025_very_long_and_secure_aakib_sheikh
JWT_EXPIRES_IN=30d

# ── EMAIL (Gmail) ──
# Use Gmail App Password (NOT your normal Gmail password)
# Gmail → Settings → Security → 2FA → App Passwords → Generate
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=sheikhaakib04@gmail.com
EMAIL_PASS=eqvnhtzubhooodqf

# ── CLIENT EMAIL (Where enquiries get sent) ──
